{
  "expo": {
    "name": "Nisibis",
    "slug": "nisibis",
    "scheme": "nisibis",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ECE0CD",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nisibis.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Nisibis, yakınındaki durakları haritada göstermek için yalnızca uygulama açıkken konumunu kullanır. Konum verisi cihazından çıkmaz."
      }
    },
    "android": {
      "package": "com.nisibis.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#A8491E"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nisibis, yakınındaki durakları haritada göstermek için yalnızca uygulama açıkken konumunu kullanır. Konum verisi cihazından çıkmaz."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#ECE0CD",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1a5e194-adad-40a3-918f-e53dc7d6e517"
      }
    }
  }
}
